{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Workspace Initialization Guard",
      "type": "shell",
      "command": "uv run --no-project .scripts/setup_git.py",
      "windows": {
        "command": "uv run --no-project .scripts/setup_git.py"
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Audit on Save",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python .scripts/audit.py '${file}'",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe .scripts/audit.py \"${file}\""
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "focus": false
      }
    }
  ]
}
